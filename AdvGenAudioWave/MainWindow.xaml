<Window x:Class="AdvGenAudioWave.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AdvGen Audio Wave" Height="500" Width="900"
        MinWidth="600" MinHeight="400"
        Loaded="Window_Loaded">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Browse -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <Button DockPanel.Dock="Left" Content="Browse MP3…" Click="Browse_Click" Width="100" Padding="6,4"/>
            <TextBox x:Name="FilePathBox" IsReadOnly="True" Margin="8,0,0,0"
                     VerticalContentAlignment="Center" Text="No file selected"
                     Background="#F5F5F5" Foreground="#888"/>
        </DockPanel>

        <!-- Row 1: Settings -->
        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Label Content="Width:" VerticalAlignment="Center"/>
            <TextBox x:Name="WidthBox" Text="1920" Width="60" Margin="0,0,12,0"
                     VerticalContentAlignment="Center" TextChanged="Settings_Changed"/>
            <Label Content="Height:" VerticalAlignment="Center"/>
            <TextBox x:Name="HeightBox" Text="200" Width="60" Margin="0,0,12,0"
                     VerticalContentAlignment="Center" TextChanged="Settings_Changed"/>
            <Label Content="Color:" VerticalAlignment="Center"/>
            <Button x:Name="ColorButton" Click="PickColor_Click" Width="90" Margin="0,0,12,0" Padding="4,4">
                <StackPanel Orientation="Horizontal">
                    <Rectangle x:Name="ColorSwatch" Width="16" Height="16" Fill="White"
                               Stroke="#AAA" StrokeThickness="1" Margin="0,0,6,0"/>
                    <TextBlock Text="Pick…" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Label Content="Frames:" VerticalAlignment="Center"/>
            <TextBox x:Name="FramesBox" Text="60" Width="55" Margin="0,0,8,0"
                     VerticalContentAlignment="Center" TextChanged="Frames_Changed"/>
            <TextBlock x:Name="FrameDelayLabel" VerticalAlignment="Center" Foreground="#555"
                       FontSize="11" Margin="0,0,0,0" Text=""/>
            <Label Content="Animation:" VerticalAlignment="Center" Margin="12,0,0,0"/>
            <ComboBox x:Name="AnimationModeBox" Width="120" SelectedIndex="2"
                      VerticalContentAlignment="Center" Margin="0,0,0,0">
                <ComboBoxItem Content="Cursor sweep"/>
                <ComboBoxItem Content="Pulse"/>
                <ComboBoxItem Content="Cursor + Pulse"/>
            </ComboBox>
        </WrapPanel>

        <!-- Row 2: Preview -->
        <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1" Background="#1A1A1A"
                CornerRadius="2">
            <Grid>
                <Image x:Name="PreviewImage" Stretch="Uniform"/>
                <TextBlock x:Name="PreviewPlaceholder" Text="Load an MP3 to see a preview"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#666" FontSize="13"/>
            </Grid>
        </Border>

        <!-- Row 3: Warning -->
        <TextBlock x:Name="WarningLabel" Grid.Row="3" Foreground="Orange"
                   Visibility="Collapsed" Margin="0,4,0,0" FontSize="11"
                   Text="Note: animation delay capped at 655 s/frame — increase frame count for accurate sync"/>

        <!-- Row 4: Export buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="ExportApngButton" Content="Export as APNG"
                    Click="ExportApng_Click" IsEnabled="False" Width="130" Padding="8,5" Margin="0,0,8,0"/>
            <Button x:Name="ExportMovButton" Content="Export as MOV"
                    Click="ExportMov_Click" IsEnabled="False" Width="130" Padding="8,5"/>
        </StackPanel>
    </Grid>
</Window>
